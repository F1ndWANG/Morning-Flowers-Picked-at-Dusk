AIGCSAR_LLM_PROVIDER=minimax-openai-compatible
AIGCSAR_LLM_API_BASE=https://api.minimaxi.com/v1
AIGCSAR_LLM_API_KEY=
AIGCSAR_LLM_MODEL=MiniMax-M2.5
AIGCSAR_VISION_MODEL=MiniMax-M2.5
AIGCSAR_AUDIO_MODEL=Speech-02-HD

AIGCSAR_IMAGE_PROVIDER=siliconflow
AIGCSAR_IMAGE_API_BASE=https://api.siliconflow.cn/v1
AIGCSAR_IMAGE_API_KEY=
AIGCSAR_IMAGE_MODEL=Qwen/Qwen-Image
AIGCSAR_IMAGE_SIZE=1328x1328
AIGCSAR_IMAGE_TIMEOUT_SECONDS=90
AIGCSAR_IMAGE_CONCURRENCY=3
AIGCSAR_IMAGE_CACHE_ENABLED=true
